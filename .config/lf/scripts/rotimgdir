#!/usr/bin/env bash

# Usage check
if [[ -z "$1" ]]; then
    echo "Usage: rotimgdir <filename>" >&2
    exit 1
fi

target=$(basename "$1")
found=false
before=()
after=()

# Use a glob instead of 'ls' to handle spaces/special characters safely
for file in *; do
    if [[ "$file" == "$target" ]]; then
        found=true
    fi

    if $found; then
        after+=("$file")
    else
        before+=("$file")
    fi
done

# If the file wasn't found, just print the normal list and exit
if ! $found; then
    printf '%s\n' "${before[@]}"
    exit 0
fi

# Print the 'pivoted' list: target and everything after, then the 'before' part
printf '%s\n' "${after[@]}" "${before[@]}"
