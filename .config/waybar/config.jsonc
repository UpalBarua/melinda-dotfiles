{
  "include": ["~/.config/waybar/modules.jsonc"],
  "layer": "top",
  "position": "top",
  "spacing": 20,
  "modules-left": ["hyprland/workspaces", "temperature", "cpu", "memory"],
  "modules-center": ["clock"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "network",
    "custom/battery",
    "tray",
  ],
}
