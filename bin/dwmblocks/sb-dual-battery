#!/bin/sh

# Get AC status (handles AC, ACAD, or ADP1 naming conventions)
ac=$(cat /sys/class/power_supply/AC*/online 2>/dev/null | head -n 1)
[ -z "$ac" ] && ac=0

# Initialize totals
total_now=0
total_full=0

# Loop through all available batteries (BAT0, BAT1, etc.)
for bat in /sys/class/power_supply/BAT*; do
    if [ -d "$bat" ]; then
        # Some systems use energy_now (mWh), others use charge_now (mAh)
        now=$(cat "$bat/energy_now" 2>/dev/null || cat "$bat/charge_now" 2>/dev/null || echo 0)
        full=$(cat "$bat/energy_full" 2>/dev/null || cat "$bat/charge_full" 2>/dev/null || echo 0)
        
        total_now=$((total_now + now))
        total_full=$((total_full + full))
    fi
done

# Calculate percentage and safeguard against division by zero
if [ "$total_full" -gt 0 ]; then
    perc=$((total_now * 100 / total_full))
    [ "$perc" -gt 100 ] && perc=100
else
    perc=0
fi

# Set icon based on AC status
if [ "$ac" -eq 1 ]; then
    icon="" # Charging icon
else
    icon="" # Battery icon
fi

# Final Output: [Icon] [Percentage]%
printf "%s %d%%\n" "$icon" "$perc"
