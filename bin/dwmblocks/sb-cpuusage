#!/bin/bash

# Get CPU usage from /proc/stat
# Using -r to prevent backslash escapes and targeting the first line
read -r _ user nice system idle iowait irq softirq steal guest guest_nice < /proc/stat

# Calculate total and idle CPU time
total=$((user + nice + system + idle + iowait + irq + softirq + steal + guest + guest_nice))
idle_total=$((idle + iowait))

CPU_USAGE_TEMP_FILE="/tmp/cpu_usage"

# Logic improvement: handle empty or corrupt temp file gracefully
if [[ -f "$CPU_USAGE_TEMP_FILE" ]]; then
    read -r prev_total prev_idle < "$CPU_USAGE_TEMP_FILE"
else
    prev_total=0
    prev_idle=0
fi

echo "$total $idle_total" > "$CPU_USAGE_TEMP_FILE"

# Calculate usage percentage with a check to prevent division by zero
usage=0
if [[ $prev_total -gt 0 ]]; then
    total_diff=$((total - prev_total))
    idle_diff=$((idle_total - prev_idle))
    if [[ $total_diff -gt 0 ]]; then
        usage=$((100 * (total_diff - idle_diff) / total_diff))
    fi
fi

# Optimized Temperature Search
TEMP_STR="No Sensor"
# We check the most likely paths first using wildcards to handle multiple hwmon inputs
for path in /sys/class/thermal/thermal_zone[0-9]/temp \
             /sys/class/hwmon/hwmon*/temp[0-9]_input \
             /sys/class/hwmon/hwmon*/device/temp[0-9]_input; do
    if [[ -f "$path" ]]; then
        # Read the first match and break
        TEMP_RAW=$(< "$path")
        TEMP_STR="$((TEMP_RAW / 1000))°C"
        break
    fi
done

# Output matches your exact style:  usage% / temp
printf " %s%% / %s\n" "$usage" "$TEMP_STR"
