#!/bin/sh

# Get volume status from pipewire/wireplumber
vol_data=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)

# Check if wpctl command succeeded
if [ $? -ne 0 ]; then
    echo " Err"
    exit 1
fi

# Handle Muted state
case "$vol_data" in
    *MUTED*)
        echo " muted"
        exit 0
        ;;
esac

# Extract volume and convert to integer (0.50 -> 50)
# This replaces the complex 'split' function and grep calls
vol=$(echo "$vol_data" | awk '{print int($2 * 100)}')

# Determine the icon based on the volume level
if [ "$vol" -ge 60 ]; then
    icon=""
elif [ "$vol" -ge 30 ]; then
    icon=""
elif [ "$vol" -ge 1 ]; then
    icon=""
else
    icon=""
fi

# Output matches your exact style: [Icon] [Vol]%
printf "%s %d%%\n" "$icon" "$vol"
