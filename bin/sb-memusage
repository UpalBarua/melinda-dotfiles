#!/bin/bash

# Read all necessary memory values in a single pass for efficiency
while read -r line; do
    case "$line" in
        MemTotal:*) total=$(echo "$line" | awk '{print $2}') ;;
        MemFree:*)  free=$(echo "$line" | awk '{print $2}') ;;
        Buffers:*)  buffers=$(echo "$line" | awk '{print $2}') ;;
        Cached:*)   cached=$(echo "$line" | awk '{print $2}') ;;
    esac
done < /proc/meminfo

# Calculate used memory (kB)
# Used = Total - Free - Buffers - Cached
used_kb=$((total - free - buffers - cached))

# Convert to GB with 1 decimal using integer arithmetic
gb=$((used_kb / 1048576))             # Whole GB
remainder=$((used_kb % 1048576))      # Remainder in kB
decimal=$((remainder * 10 / 1048576)) # 1st decimal digit

# Output matches your exact style: ¯ª« X.X GB
printf "¯ª« %d.%d GB\n" "$gb" "$decimal"
